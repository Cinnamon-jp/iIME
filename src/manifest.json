{
  "name": "iIME",
  "version": "1.3",
  "manifest_version": 3,
  "icons": {
    "16": "img/icon.png",
    "48": "img/icon.png",
    "128": "img/icon.png"
  },
  "action": {
    "default_icon": {
      "16": "img/icon.png",
      "48": "img/icon.png",
      "128": "img/icon.png"
    }
  },
  "description": "Googleの検索窓の入力を書き換えます。",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/*",
        "https://www.google.co.jp/*",
        "https://www.yahoo.co.jp/*"
      ],
      "js": [

        "js/dictionary.js",
        "js/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "words.txt"
      ],
      "matches": [
        "https://www.google.com/*",
        "https://www.google.co.jp/*"
      ]
    }
  ]
}