{
  "name": "iIME",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Googleの検索窓の入力を書き換えます。",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/*",
        "https://www.google.co.jp/*"
      ],
      "js": [
        "dictionary.js",
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "words.txt"
      ],
      "matches": [
        "https://www.google.com/*",
        "https://www.google.co.jp/*"
      ]
    }
  ]
}